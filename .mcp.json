{
  "mcpServers": {
    "lego-robot": {
      "command": ".venv/bin/mcpmon",
      "args": ["--watch", "mcp_robot", "--", ".venv/bin/python3", "-m", "mcp_robot.server"],
      "env": {
        "ROBOT_HOST": "rpi.local",
        "ROBOT_USER": "rpi",
        "RERUN_ENABLED": "1",
        "PYTHONUNBUFFERED": "1",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "experience-memory": {
      "command": ".venv/bin/python3",
      "args": ["-m", "mcp_memory_service.server"],
      "env": {
        "MCP_MEMORY_SQLITE_PATH": "/home/navatm/Projects/lego-robot-mcp/memory/experiences.db",
        "MCP_MEMORY_BASE_DIR": "/home/navatm/Projects/lego-robot-mcp/memory",
        "MCP_CONSOLIDATION_ENABLED": "true",
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
